  #binding-cells = <0>;
  bindings = <&kp SE_FSLH>, <&kp SE_QMARK>;
  mods = <(MOD_LSFT|MOD_RSFT)>;
};

// 2 @
se_n2: si-2-at {
  compatible = "zmk,behavior-mod-morph";
