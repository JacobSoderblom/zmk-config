// Behaviors to support US like symbols when host layoust is SI

// ; :
se_semi: si-semicolon-colon {
  compatible = "zmk,behavior-mod-morph";
  label = "SE_SEMI_COLO";
  #binding-cells = <0>;
  bindings = <&kp SE_SCLN>, <&kp SE_COLN>;
  mods = <(MOD_LSFT|MOD_RSFT)>;
};

// = +
se_equal: si-equal-plus {
  compatible = "zmk,behavior-mod-morph";
  label = "SE_EQUAL_PLUS";
  #binding-cells = <0>;
  bindings = <&kp SE_EQUAL>, <&kp SE_PLUS>;
  mods = <(MOD_LSFT|MOD_RSFT)>;
};

// ' "
se_sqt: si-sqt-dqt {
  compatible = "zmk,behavior-mod-morph";
  label = "SE_SQT_DQT";
  #binding-cells = <0>;
  bindings = <&kp SE_SQT>, <&kp SE_DQT>;
  mods = <(MOD_LSFT|MOD_RSFT)>;
};

// , <
se_comma: si-comma-lt {
  compatible = "zmk,behavior-mod-morph";
  label = "SE_COMMA_LT";
  #binding-cells = <0>;
  bindings = <&kp SE_COMMA>, <&kp SE_LT>;
  mods = <(MOD_LSFT|MOD_RSFT)>;
};

// . >
